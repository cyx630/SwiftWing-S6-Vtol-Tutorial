5f00\u59cb\u5411\u524d\u52a0\u901f \u65cb\u7ffc\u5230\u56fa\u5b9a\u7ffc\u7684\u503e\u8f6c\u8fc7\u7a0b \u98de\u884c\u6a21\u5f0f\u7531MR\uff08VTOL\uff09\u53d8\u4e3aFW\uff08VTOL\uff09 \u524d\u9762\u4e24\u4e2a\u503e\u8f6c\u8235\u673a\u63a7\u5236\u7535\u673a\u5b8c\u5168\u5411\u524d \u5728\u56fa\u5b9a\u7ffc\u7684\u5b9a\u70b9\u6a21\u5f0f\u4e0b\u624b\u52a8\u64cd\u63a7\u98de\u884c \u98de\u624b\u65f6\u523b\u6ce8\u610f\u65e0\u4eba\u673a\uff0c\u5728FW\uff08VTOL\uff09\u4e0b\u901a\u8fc7\u9065\u63a7\u5668\u624b\u52a8\u63a7\u5236\u65e0\u4eba\u673a\u98de\u884c \u624b\u52a8\u63a7\u5236\u98de\u884c \u5728\u56fa\u5b9a\u7ffc\u6a21\u5f0f\u4e0b\u6839\u636e\u98de\u624b\u4e60\u60ef\u624b\u52a8\u63a7\u5236\u98de\u884c \u964d\u843d \u5728\u56fa\u5b9a\u7ffc\u7684\u5b9a\u70b9\u6a21\u5f0f\u4e0b\u964d\u4f4e\u98de\u884c\u9ad8\u5ea6\u3001\u98de\u884c\u901f\u5ea6\u3001\u98de\u884c\u5230\u964d\u843d\u533a\u57df \u572822\u7c73\u9ad8\uff0c13\u7c73\u6bcf\u79d2\u901f\u5ea6\u4e0b\uff0c\u62e8\u52a8VTOL\u5207\u6362\u901a\u9053\uff0c\u5f00\u59cb\u8fdb\u5165\u5207\u6362\u8fc7\u7a0b \u56fa\u5b9a\u7ffc\u5230\u65cb\u7ffc\u7684\u503e\u8f6c\u8fc7\u7a0b \u98de\u884c\u6a21\u5f0f\u7531FW\uff08VTOL\uff09\u53d8\u4e3aMR\uff08VTOL\uff09 \u524d\u9762\u4e24\u4e2a\u503e\u8f6c\u8235\u673a\u63a7\u5236\u7535\u673a\u7531\u5b8c\u5168\u5411\u524d\uff0c\u53d8\u4e3a\u5411\u4e0a \u5728\u65cb\u7ffc\u7684\u5b9a\u70b9\u6a21\u5f0f\u4e0b\u624b\u52a8\u64cd\u63a7\u65e0\u4eba\u673a \u624b\u52a8\u63a7\u5236\u65e0\u4eba\u673a\u964d\u843d\u5373\u53ef \u7b49\u65e0\u4eba\u673a\u63a5\u89e6\u5730\u9762\u540e\uff0c\u6301\u7eed\u62c9\u4f4e\u6cb9\u95e8\uff0c\u7b49\u5f85\u7535\u673a\u4e0a\u9501\u5373\u53ef\u5b8c\u6210\u672c\u6b21\u98de\u884c","title":"\u624b\u52a8\u98de\u884c\u4ecb\u7ecd"},{"location":"%E8%BF%9B%E9%98%B6%E9%A3%9E%E8%A1%8C/%E6%89%8B%E5%8A%A8%E9%A3%9E%E8%A1%8C%E4%BB%8B%E7%BB%8D/#_1","text":"\u6839\u636e\u524d\u9762\u6559\u7a0b\uff0c\u51c6\u5907\u597d\u786c\u4ef6\u3001\u8f6f\u4ef6 \u9996\u6b21\u98de\u884c\u4ecb\u7ecd\u57fa\u4e8e\u98de\u6